<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Always-dark: PITO is a terminal. Black colorBackground also kills the
         WebView white flash; black colorSurface feeds the Custom Tab toolbar. -->
    <style name="Theme.Pito" parent="Theme.Material3.Dark.NoActionBar">
        <!-- DejaVu Sans Mono everywhere — native chrome matches the web UI. -->
        <item name="android:fontFamily">@font/pito_mono</item>
        <item name="fontFamily">@font/pito_mono</item>
        <item name="android:colorBackground">@color/black</item>
        <item name="colorSurface">@color/black</item>
        <item name="colorPrimary">@color/pito_blue</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
