{
  "settings": {},
  "rules": [
    {
      "patterns": [".*"],
      "properties": {
        "context": "default",
        "uri": "hotwire://fragment/web",
        "fallback_uri": "hotwire://fragment/web",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": ["^$", "^/$"],
      "properties": {
        "presentation": "clear_all"
      }
    }
  ]
}
