# Gradle build state and outputs
.gradle/
build/
.kotlin/

# Machine-specific SDK location (sdk.dir) — never committed
local.properties

# Signing keystores — the release key must NEVER enter git history
*.jks
*.keystore

# Scratch — the FOLDER is tracked (via .keep) so it exists in fresh clones;
# its CONTENTS never are. google-services.json and the Firebase
# service-account key live here locally — secrets treatment, never in git
# (CI gets google-services.json as a base64 secret instead).
/tmp/*
!/tmp/.keep

# Firebase config — app/build.gradle.kts mirrors tmp/google-services.json here
# locally; CI decodes it from a secret. Never committed either way.
/app/google-services.json

# Editor
.idea/
.vscode/

# Claude settings.json is committed; everything else in .claude/ (local
# settings, runtime state) stays machine-local.
.claude/*
!.claude/settings.json
