# Gradle build state and outputs
.gradle/
build/
.kotlin/

# Machine-specific SDK location (sdk.dir) — never committed
local.properties

# Signing keystores — the release key must NEVER enter git history
*.jks
*.keystore

# Agent working docs (plans/specs/briefs) — local only
/docs/claude/

# Scratch
/tmp/

# Editor
.idea/
.vscode/

# Claude guardrails ship with the repo (pito model): hooks + settings.json
# are committed; everything else in .claude/ (local settings, runtime state)
# stays machine-local.
.claude/*
!.claude/hooks/
!.claude/settings.json
